{
  "name": "resumer",
  "version": "2.0.0",
  "description": "Local-first, markdown-powered, AI-native resume builder with embedded real-time ATS scoring",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "dev": "live-server --port=8000 --open=index.html --ignore=node_modules,.git",
    "test": "node --experimental-vm-modules node_modules/.bin/jest",
    "test:watch": "node --experimental-vm-modules node_modules/.bin/jest --watch",
    "test:coverage": "node --experimental-vm-modules node_modules/.bin/jest --coverage",
    "lint": "eslint src/ tests/ --ext .js",
    "lint:fix": "eslint src/ tests/ --ext .js --fix"
  },
  "devDependencies": {
    "eslint": "^9.0.0",
    "jest": "^29.0.0",
    "live-server": "^1.2.2"
  },
  "jest": {
    "testEnvironment": "node",
    "testMatch": ["**/tests/**/*.test.js"],
    "transform": {}
  },
  "eslintConfig": {
    "env": {
      "browser": true,
      "es2022": true
    },
    "parserOptions": {
      "ecmaVersion": 2022,
      "sourceType": "module"
    },
    "rules": {
      "no-unused-vars": "warn",
      "no-console": "off"
    }
  },
  "keywords": [
    "resume",
    "resume-builder",
    "ats",
    "ats-optimizer",
    "markdown",
    "ai-powered",
    "job-search",
    "cover-letter",
    "open-source"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/yourusername/resumer"
  },
  "homepage": "https://github.com/yourusername/resumer#readme",
  "bugs": {
    "url": "https://github.com/yourusername/resumer/issues"
  }
}
