{
  "name": "resumer",
  "version": "2.0.0",
  "description": "Local-first, markdown-powered, AI-native resume builder with embedded real-time ATS scoring",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "vercel-build": "",
    "dev": "live-server --port=8000 --open=index.html --ignore=node_modules,.git",
    "test": "node --experimental-vm-modules node_modules/.bin/jest",
    "test:watch": "node --experimental-vm-modules node_modules/.bin/jest --watch",
    "test:coverage": "node --experimental-vm-modules node_modules/.bin/jest --coverage",
    "lint": "eslint src/ tests/ app.js && markdownlint '**/*.md' --ignore node_modules --ignore PLAN.md --ignore .github",
    "lint:fix": "eslint src/ tests/ app.js --fix && markdownlint --fix '**/*.md' --ignore node_modules --ignore PLAN.md --ignore .github"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "eslint": "^9.0.0",
    "eslint-plugin-markdown": "^5.1.0",
    "globals": "^17.7.0",
    "jest": "^29.0.0",
    "live-server": "^1.2.2",
    "markdownlint-cli": "^0.48.0"
  },
  "jest": {
    "testEnvironment": "node",
    "testMatch": [
      "**/tests/**/*.test.js"
    ],
    "transform": {}
  },
  "keywords": [
    "resume",
    "resume-builder",
    "ats",
    "ats-optimizer",
    "markdown",
    "ai-powered",
    "job-search",
    "cover-letter",
    "open-source"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/ENGXLABS/RESUMER"
  },
  "homepage": "https://github.com/ENGXLABS/RESUMER#readme",
  "bugs": {
    "url": "https://github.com/ENGXLABS/RESUMER/issues"
  }
}
